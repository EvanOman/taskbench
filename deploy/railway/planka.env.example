# Planka environment variables for Railway deployment.
# Copy to .env.cloud (gitignored) and fill in real values.
# These are also set in the Railway dashboard under the Planka service.

DATABASE_URL=postgres://postgres:password@postgres.railway.internal:5432/railway
BASE_URL=https://planka-prod-xxxx.up.railway.app
SECRET_KEY=<generate with: openssl rand -hex 64>
DEFAULT_ADMIN_EMAIL=admin@taskflow.cloud
DEFAULT_ADMIN_PASSWORD=<set in Railway dashboard — do NOT commit>
DEFAULT_ADMIN_NAME=Admin
DEFAULT_ADMIN_USERNAME=admin
TRUST_PROXY=1
